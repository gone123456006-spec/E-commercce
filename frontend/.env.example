# API Configuration
# Production: your Render API URL (required on Vercel/Netlify for cross-device product sync)
VITE_API_BASE_URL=https://ecommerce-api-6y9p.onrender.com

# Local dev: leave unset to use Vite proxy → http://localhost:5000 (run backend with npm run dev)

# App Configuration
VITE_APP_NAME=ShopZone
VITE_APP_VERSION=1.0.0

# Environment
VITE_NODE_ENV=development

# Firebase (Phone Auth) — copy from Firebase Console → Project settings → Your apps → Web
# When all keys below are set, login uses Firebase SMS OTP + backend /api/auth/firebase-verify
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=
