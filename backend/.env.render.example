# Copy these as Environment variables in Render: Dashboard → your Web Service → Environment
# Do NOT commit real secrets. Render injects PORT automatically — do not define PORT here.

NODE_ENV=production

# Required — MongoDB Atlas (or other). Network Access: allow 0.0.0.0/0 for Render outbound IPs.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ecommerce_db?retryWrites=true&w=majority

# Required — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=c2e8a93b4d5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z7a8b9c0d1e
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=Ar@v1234

# Optional — your deployed frontend URL(s) for stricter CORS (e.g. https://your-app.onrender.com)
# If omitted, the API still runs; CORS falls back to reflecting the request Origin.
FRONTEND_URL=

# Required for customer login — full service account JSON as one line (Firebase Console → Service accounts)
FIREBASE_SERVICE_ACCOUNT_JSON=
