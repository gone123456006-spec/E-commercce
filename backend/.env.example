# ──────────────────────────────────────────────────────────
# ECOMMERCE BACKEND — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.
# ──────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # use 'production' on Render

# ── Database (MongoDB Atlas) ──────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ecommerce_db?retryWrites=true&w=majority&appName=Cluster0

# ── Auth & Security ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=Ar@v1234

# ── CORS (Production only) ────────────────────────────────
# Set to your deployed frontend URL. Multiple URLs allowed
# as a comma-separated list:
#   https://my-shop.vercel.app,https://my-admin.netlify.app
FRONTEND_URL=http://localhost:5173

# ── Firebase Admin (Phone Auth → JWT) ─────────────────────
# Download service account JSON from Firebase Console → Project settings → Service accounts
# Paste the ENTIRE JSON as ONE line (Render/Vercel friendly), e.g. {"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_JSON=
